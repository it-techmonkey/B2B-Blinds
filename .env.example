# =============================================================================
# Database
# =============================================================================
#
# --- Local Postgres (Homebrew / Docker) ---
# DATABASE_URL="postgresql://YOUR_USER@localhost:5432/b2b_oms?schema=public"
#
# --- Neon (cloud) — copy user, password, host from Neon Console → Connect ---
# Free projects auto-suspend: open https://console.neon.tech and your project
# (or run a query) to wake it before the app can connect.
#
# Use the **pooled** host (ends in -pooler) for the app. Add sslmode + pgbouncer
# so Prisma works with Neon's pooler:
#
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=30"
#
# Migrations: Neon recommends a separate **direct** (non-pooler) URL for
# `prisma migrate`. In Neon: same branch → Connection details → use the
# hostname WITHOUT "-pooler" for DIRECT_URL, then in prisma/schema.prisma add:
#   directUrl = env("DIRECT_URL")
# and set:
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
#
# If migrate works with only DATABASE_URL, you can skip directUrl.
#
# Common failures:
# - P1001 / "Can't reach database" → project asleep, wrong password, VPN/firewall
#   blocking port 5432, or DATABASE_URL missing ?sslmode=require
#
# This app: if DATABASE_URL host contains "neon.tech", Prisma uses Neon's
# serverless driver over WebSockets (see src/lib/db.ts), which often fixes P1001
# when plain TCP :5432 is blocked on your network.
#
# =============================================================================

DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/b2b_oms?schema=public"
# Local: duplicate DATABASE_URL. Neon: unpooled connection string (host without -pooler).
DIRECT_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/b2b_oms?schema=public"

# JWT secret — use a long random string in production
JWT_SECRET="ec7c4f2e8e02281fc50f1872692fa7a0d1ee98d80566edd7035a954006f6dd38"

# Single admin bootstrap (prisma seed). Seed syncs this password on every run for the ADMIN user.
# Use the same email at /login (case-insensitive). Put DATABASE_URL in .env or .env.local — seed loads both like Next.js.
ADMIN_EMAIL="admin@blinds.com"
ADMIN_PASSWORD="BlindsAdmin#2026!"
